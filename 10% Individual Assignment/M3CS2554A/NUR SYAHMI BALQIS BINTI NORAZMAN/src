import time
import random
import threading
import multiprocessing
from concurrent.futures import ThreadPoolExecutor, ProcessPoolExecutor

# ==================== DATA GENERATION ====================

def generate_data():
    """Generate 10,000 user-song listening records"""
    print("Generating 10,000 listening records...")
    data = []
    for i in range(10000):
        user_id = random.randint(1, 1000)
        song_id = random.randint(1, 500)
        listens = random.randint(1, 100)
        data.append((user_id, song_id, listens))
    return data

# ==================== RECOMMENDATION ENGINE ====================

def get_user_history(data, user_id):
    """Get all songs listened by a user (CPU intensive)"""
    history = {}
    for uid, song, listens in data:
        if uid == user_id:
            history[song] = listens
    return history

def calculate_similarity(history1, history2):
    """Calculate similarity between two users (CPU intensive)"""
    common = set(history1.keys()) & set(history2.keys())
    if not common:
        return 0
    
    # Simple similarity score
    score = sum(min(history1[song], history2[song]) for song in common)
    return score / (len(history1) + len(history2))

def recommend_for_user(data, target_user, all_users):
    """Generate recommendations for a single user"""
    target_history = get_user_history(data, target_user)
    
    # Find similar users
    similarities = []
    for user in all_users:
        if user != target_user:
            user_history = get_user_history(data, user)
            sim = calculate_similarity(target_history, user_history)
            similarities.append((user, sim))
    
    # Sort by similarity and get top 3 similar users
    similarities.sort(key=lambda x: x[1], reverse=True)
    top_users = similarities[:3]
    
    # Recommend songs from similar users
    recommendations = {}
    for user, sim in top_users:
        user_history = get_user_history(data, user)
        for song, listens in user_history.items():
            if song not in target_history:
                recommendations[song] = recommendations.get(song, 0) + listens * sim
    
    # Return top 5 recommendations
    top_songs = sorted(recommendations.items(), key=lambda x: x[1], reverse=True)[:5]
    return [song for song, score in top_songs]

# ==================== SEQUENTIAL VERSION ====================

def run_sequential(data, target_users):
    """Process users one by one"""
    print("\nSEQUENTIAL Processing...")
    start = time.time()
    
    all_users = list(set(uid for uid, _, _ in data))
    results = []
    for user in target_users:
        recs = recommend_for_user(data, user, all_users)
        results.append(recs)
    
    elapsed = time.time() - start
    print(f"Completed in {elapsed:.2f} seconds")
    return results, elapsed

# ==================== CONCURRENT VERSION (THREADING) ====================

def run_concurrent(data, target_users):
    """Process users concurrently using threads"""
    print("\nCONCURRENT - Threading Processing...")
    start = time.time()
    
    all_users = list(set(uid for uid, _, _ in data))
    results = [None] * len(target_users)
    
    def process_user(idx, user):
        results[idx] = recommend_for_user(data, user, all_users)
    
    with ThreadPoolExecutor(max_workers=4) as executor:
        for idx, user in enumerate(target_users):
            executor.submit(process_user, idx, user)
    
    elapsed = time.time() - start
    print(f"Completed in {elapsed:.2f} seconds")
    return results, elapsed

# ==================== PARALLEL VERSION (MULTIPROCESSING) ====================

def process_user_wrapper(args):
    """Wrapper function for multiprocessing"""
    data, user, all_users = args
    return recommend_for_user(data, user, all_users)

def run_parallel(data, target_users):
    """Process users in parallel using multiple processes"""
    print("\nPARALLEL - Multiprocessing Processing...")
    start = time.time()
    
    all_users = list(set(uid for uid, _, _ in data))
    
    # Prepare arguments for each process
    args_list = [(data, user, all_users) for user in target_users]
    
    with ProcessPoolExecutor(max_workers=4) as executor:
        results = list(executor.map(process_user_wrapper, args_list))
    
    elapsed = time.time() - start
    print(f"Completed in {elapsed:.2f} seconds")
    return results, elapsed

# ==================== MAIN PROGRAM ====================

def main():
    print("=" * 50)
    print("SIMPLE PARALLEL MUSIC RECOMMENDER")
    print("=" * 50)
    
    # Generate data
    data = generate_data()
    print(f"Generated {len(data)} records for 1000 users and 500 songs")
    
    # Select 10 random users to recommend for
    target_users = random.sample(range(1, 1001), 10)
    print(f"Generating recommendations for {len(target_users)} users...")
    
    # Run all three methods
    seq_results, seq_time = run_sequential(data, target_users)
    con_results, con_time = run_concurrent(data, target_users)
    par_results, par_time = run_parallel(data, target_users)
    
    # Performance comparison
    print("\n" + "=" * 50)
    print("PERFORMANCE COMPARISON")
    print("=" * 50)
    print(f"{'Method':<25} {'Time (seconds)':<15} {'Speedup':<10}")
    print("-" * 50)
    print(f"{'Sequential':<25} {seq_time:<15.2f} {'1.00x':<10}")
    print(f"{'Concurrent (Threads)':<25} {con_time:<15.2f} {seq_time/con_time:<10.2f}x")
    print(f"{'Parallel (Processes)':<25} {par_time:<15.2f} {seq_time/par_time:<10.2f}x")
    
    # Show sample output
    print("\n" + "=" * 50)
    print("SAMPLE RECOMMENDATIONS (Parallel Method)")
    print("=" * 50)
    for i, user in enumerate(target_users[:3]):
        print(f"\nUser {user}: Recommended songs {par_results[i][:3]}")
    
    print("\nProgram complete! Parallel processing is fastest for CPU-intensive tasks.")

if __name__ == "__main__":
    multiprocessing.freeze_support()
    main()
